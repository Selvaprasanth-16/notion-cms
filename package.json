{
  "name": "@selvaprasanth/notion-cms",
  "version": "1.2.1",
  "description": "Notion CMS renderer for React and Next.js",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "default": "./index.js"
    },
    "./styles": "./styles/notion.css"
  },
  "files": [
    "dist",
    "styles",
    "index.js",
    "README.md"
  ],
  "keywords": [
    "notion",
    "cms",
    "react",
    "nextjs",
    "notion-api",
    "react-notion-x"
  ],
  "author": "Selvaprasanth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Selvaprasanth-16/notion-cms.git"
  },
  "homepage": "https://github.com/Selvaprasanth-16/notion-cms#readme",
  "bugs": {
    "url": "https://github.com/Selvaprasanth-16/notion-cms/issues"
  },
  "scripts": {
    "build": "rm -rf dist && babel components core --out-dir dist --extensions .js,.jsx"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "next": ">=13"
  },
  "dependencies": {
    "@notionhq/client": "^2.3.0",
    "notion-client": "^7.10.0",
    "react-notion-x": "^7.10.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/core": "^7.27.1",
    "@babel/preset-react": "^7.27.1"
  }
}
